generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Category {
  id          Int           @id @default(autoincrement())
  csvId       String        @unique @map("csv_id")
  name        String
  slug        String        @unique
  image       String?
  sortOrder   Int           @default(0) @map("sort_order")
  isActive    Boolean       @default(true) @map("is_active")
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  subcategories Subcategory[]
  products      Product[]

  @@map("categories")
}

model Subcategory {
  id          Int       @id @default(autoincrement())
  csvId       String    @unique @map("csv_id")
  categoryId  Int       @map("category_id")
  name        String
  slug        String    @unique
  image       String?
  sortOrder   Int       @default(0) @map("sort_order")
  isActive    Boolean   @default(true) @map("is_active")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  category Category @relation(fields: [categoryId], references: [id])
  products Product[]

  @@map("subcategories")
}

model Brand {
  id          Int       @id @default(autoincrement())
  csvId       String    @unique @map("csv_id")
  name        String
  slug        String    @unique
  logo        String?
  isActive    Boolean   @default(true) @map("is_active")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  products Product[]

  @@map("brands")
}

model Product {
  id              Int             @id @default(autoincrement())
  csvId           String          @unique @map("csv_id")
  sku             String          @unique
  barcode         String?
  brandId         Int?            @map("brand_id")
  categoryId      Int             @map("category_id")
  subcategoryId   Int?            @map("subcategory_id")
  name            String
  slug            String          @unique
  description     String?
  ingredients     String?
  storage         String?
  countryOfOrigin String?         @map("country_of_origin")
  manufacturer    String?
  veg             Boolean         @default(true)
  fssaiRequired   String?         @map("fssai_required")
  gstRate         Float?          @map("gst_rate")
  rating          Float?          @default(0)
  ratingCount     Int?            @default(0) @map("rating_count")
  isFeatured      Boolean         @default(false) @map("is_featured")
  isTopPick       Boolean         @default(false) @map("is_top_pick")
  isBestseller    Boolean         @default(false) @map("is_bestseller")
  isFresh         Boolean         @default(false) @map("is_fresh")
  isOffer         Boolean         @default(false) @map("is_offer")
  isActive        Boolean         @default(true) @map("is_active")
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")

  category     Category           @relation(fields: [categoryId], references: [id])
  subcategory  Subcategory?       @relation(fields: [subcategoryId], references: [id])
  brand        Brand?             @relation(fields: [brandId], references: [id])
  variants      ProductVariant[]
  images        ProductImage[]
  topPicks      TopPick[]
  cartItems     CartItem[]
  reviews       Review[]
  wishlistItems WishlistItem[]

  @@index([categoryId])
  @@index([subcategoryId])
  @@index([brandId])
  @@index([slug])
  @@index([sku])
  @@map("products")
}

model ProductVariant {
  id             Int           @id @default(autoincrement())
  csvId          String        @unique @map("csv_id")
  productId      Int           @map("product_id")
  sku            String        @unique
  variant        String?
  unit           String?
  mrp            Decimal       @default(0)
  sellingPrice   Decimal       @map("selling_price")
  discountPercent Float?       @map("discount_percent")
  stock          Int           @default(0)
  weight         String?
  isDefault      Boolean       @default(false) @map("is_default")
  isActive       Boolean       @default(true) @map("is_active")
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")

  product Product           @relation(fields: [productId], references: [id])
  images  ProductImage[]

  @@index([productId])
  @@index([sku])
  @@map("product_variants")
}

model ProductImage {
  id         Int           @id @default(autoincrement())
  csvId      String        @unique @map("csv_id")
  productId  Int           @map("product_id")
  variantId  Int?          @map("variant_id")
  image      String
  thumbnail  String?
  altText    String?
  sortOrder  Int           @default(0) @map("sort_order")
  isPrimary  Boolean       @default(false) @map("is_primary")
  createdAt  DateTime      @default(now()) @map("created_at")
  updatedAt  DateTime      @updatedAt @map("updated_at")

  product Product         @relation(fields: [productId], references: [id])
  variant ProductVariant? @relation(fields: [variantId], references: [id])

  @@index([productId])
  @@index([variantId])
  @@map("product_images")
}

model TopPick {
  id          Int      @id @default(autoincrement())
  csvId       String   @unique @map("csv_id")
  sectionName String   @map("section_name")
  sectionSlug String   @map("section_slug")
  productId   Int      @map("product_id")
  sortOrder   Int      @default(0) @map("sort_order")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  product Product @relation(fields: [productId], references: [id])

  @@index([productId])
  @@index([sectionSlug])
  @@map("top_picks")
}

model Offer {
  id           Int       @id @default(autoincrement())
  csvId        String    @unique @map("csv_id")
  title        String
  type         String
  value        Decimal   @default(0)
  minOrderValue Decimal? @map("min_order_value")
  code         String    @unique
  isActive     Boolean   @default(true) @map("is_active")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  @@map("offers")
}

enum UserRole {
  customer
  admin
  warehouse
  delivery
}

model User {
  id            Int       @id @default(autoincrement())
  name          String
  email         String    @unique
  phone         String?   @unique
  password      String
  role          UserRole  @default(customer)
  avatar        String?
  isVerified    Boolean   @default(false) @map("is_verified")
  isActive      Boolean   @default(true) @map("is_active")
  walletBalance Decimal   @default(0) @map("wallet_balance")
  fcmToken      String?   @map("fcm_token")
  refreshToken  String?   @map("refresh_token")
  lastLogin     DateTime? @map("last_login")
  isAvailable   Boolean   @default(true) @map("is_available")
  otp           String?
  otpExpiry     DateTime? @map("otp_expiry")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  addresses     Address[]
  orders        Order[]
  reviews       Review[]
  notifications Notification[]
  walletTxns    WalletTransaction[]
  wishlistItems WishlistItem[]
  cartItems     CartItem[]

  @@map("users")
}

model Address {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  label     String   @default("Home")
  name      String
  phone     String
  line1     String
  line2     String   @default("")
  city      String
  state     String
  pincode   String
  country   String   @default("India")
  latitude  Float?
  longitude Float?
  isDefault Boolean  @default(false) @map("is_default")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("addresses")
}

enum OrderStatus {
  pending
  confirmed
  preparing
  ready
  picked_up
  out_for_delivery
  delivered
  cancelled
  returned
}

enum PaymentStatus {
  pending
  paid
  failed
  refunded
}

enum PaymentMethod {
  cod
  card
  wallet
  upi
}

model Order {
  id                Int           @id @default(autoincrement())
  orderNumber       String        @unique @map("order_number")
  userId            Int           @map("user_id")
  deliveryPartnerId Int?          @map("delivery_partner_id")
  status            OrderStatus   @default(pending)
  paymentStatus     PaymentStatus @default(pending) @map("payment_status")
  paymentMethod     PaymentMethod @default(cod) @map("payment_method")
  paymentId         String?       @map("payment_id")
  subtotal          Decimal
  discount          Decimal       @default(0)
  deliveryFee       Decimal       @default(0) @map("delivery_fee")
  tax               Decimal       @default(0)
  totalAmount       Decimal       @map("total_amount")
  couponCode        String?       @map("coupon_code")
  couponDiscount    Decimal       @default(0) @map("coupon_discount")
  deliveryAddress   Json
  notes             String        @default("")
  estimatedTime     Int           @default(30) @map("estimated_time")
  deliveredAt       DateTime?     @map("delivered_at")
  cancelledAt       DateTime?     @map("cancelled_at")
  cancelReason      String?       @map("cancel_reason")
  otp               String?
  createdAt         DateTime      @default(now()) @map("created_at")
  updatedAt         DateTime      @updatedAt @map("updated_at")

  user  User        @relation(fields: [userId], references: [id])
  items OrderItem[]

  @@index([userId])
  @@index([status])
  @@index([paymentStatus])
  @@index([deliveryPartnerId])
  @@index([orderNumber])
  @@map("orders")
}

model OrderItem {
  id           Int    @id @default(autoincrement())
  orderId      Int    @map("order_id")
  productId    Int    @map("product_id")
  variantId    Int?   @map("variant_id")
  productName  String @map("product_name")
  productImage String? @map("product_image")
  variantLabel String? @map("variant_label")
  price        Decimal
  quantity     Int
  subtotal     Decimal

  order Order @relation(fields: [orderId], references: [id])

  @@index([orderId])
  @@map("order_items")
}

model CartItem {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  productId Int      @map("product_id")
  variantId Int?     @map("variant_id")
  quantity  Int      @default(1)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user    User    @relation(fields: [userId], references: [id])
  product Product @relation(fields: [productId], references: [id])

  @@unique([userId, productId, variantId])
  @@index([userId])
  @@map("cart_items")
}

model Review {
  id         Int      @id @default(autoincrement())
  userId     Int      @map("user_id")
  productId  Int      @map("product_id")
  orderId    Int?     @map("order_id")
  rating     Int
  comment    String   @default("")
  images     Json     @default("[]")
  isVerified Boolean  @default(false) @map("is_verified")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  user    User    @relation(fields: [userId], references: [id])
  product Product @relation(fields: [productId], references: [id])

  @@unique([userId, productId])
  @@index([productId])
  @@map("reviews")
}

model Coupon {
  id           Int       @id @default(autoincrement())
  code         String    @unique
  description  String    @default("")
  type         String    @default("percentage")
  value        Decimal
  minOrderValue Decimal  @default(0) @map("min_order_value")
  maxDiscount  Decimal?  @map("max_discount")
  usageLimit   Int?      @map("usage_limit")
  usedCount    Int       @default(0) @map("used_count")
  isActive     Boolean   @default(true) @map("is_active")
  expiresAt    DateTime? @map("expires_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  @@map("coupons")
}

model Notification {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  title     String
  body      String
  type      String   @default("general")
  data      Json     @default("{}")
  isRead    Boolean  @default(false) @map("is_read")
  imageUrl  String?  @map("image_url")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("notifications")
}

model WalletTransaction {
  id          Int      @id @default(autoincrement())
  userId      Int      @map("user_id")
  type        String
  amount      Decimal
  balance     Decimal
  description String   @default("")
  referenceId String?  @map("reference_id")
  createdAt   DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("wallet_transactions")
}

model WishlistItem {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  productId Int      @map("product_id")
  createdAt DateTime @default(now()) @map("created_at")

  user    User    @relation(fields: [userId], references: [id])
  product Product @relation(fields: [productId], references: [id])

  @@unique([userId, productId])
  @@index([userId])
  @@map("wishlist_items")
}
